<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd">

	<bean id="address" class="com.ibc.training.Address">
		<property name="addressLine1" value="no 15/4 thiru street" />
		<property name="addressLine2" value="vellore-632006" />
	</bean>
	<bean id="empobject" class="com.ibc.training.Employee">
		<property name="empid" value="101" />
		<property name="ename" value="sridar" />
		<property name="salary" value="10000.0" />
		<property name="address" ref="address" />
		<property name="phoneNumbers">
			<list>
				<value>123-456-7890</value>
				<value>098-765-4321</value>
			</list>
		</property>
		<property name="skills">
			<set>
				<value>Java</value>
				<value>Spring</value>
				<value>Hibernate</value>
			</set>
		</property>
		<property name="courses">
			<map>
				<entry key="101" value="Java Basics" />
				<entry key="102" value="Spring Framework" />
			</map>
		</property>
		<property name="additionalInfo">
			<props>
				<prop key="team">Development</prop>
				<prop key="project">Spring Migration</prop>
			</props>
		</property>
	</bean>
</beans>
